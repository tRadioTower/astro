---
const { title = "エレメントリスト" } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="format-detection" content="telephone=no" />
    <title>{title}</title>
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="stylesheet" href="/common/css/common.css" />
    <link rel="stylesheet" href="/common/css/jquery.mCustomScrollbar.css" />
    <link rel="stylesheet" href="/common/css/print.css" media="print" />
    <link rel="stylesheet" href="/creditcard/point/scene/css/page.css" />
  </head>
  <body>
    <main class="element-list">
      <header class="element-list__header">
        <div class="element-list__header-inner">
          <h1 class="element-list__title">{title}</h1>
          <div class="element-list__tools">
            <input
              class="element-list__search"
              type="search"
              placeholder="タイトル・HTMLで検索"
              aria-label="エレメントを検索"
              data-element-search
            />
          </div>
        </div>
      </header>
      <p class="element-list__empty" data-element-empty hidden>該当するエレメントはありません。</p>
      <div class="element-list__body">
        <slot />
      </div>
    </main>

    <script is:inline>
      document.addEventListener("click", async (event) => {
        const button = event.target.closest("[data-copy-source]");
        if (!button) return;

        const source = document.getElementById(button.dataset.copySource);
        if (!source) return;

        try {
          await navigator.clipboard.writeText(source.value);
          button.textContent = "コピー済み";
          window.setTimeout(() => {
            button.textContent = "コピー";
          }, 1400);
        } catch {
          source.hidden = false;
          source.select();
          document.execCommand("copy");
          source.hidden = true;
          button.textContent = "コピー済み";
          window.setTimeout(() => {
            button.textContent = "コピー";
          }, 1400);
        }
      });

      const searchInput = document.querySelector("[data-element-search]");
      const emptyMessage = document.querySelector("[data-element-empty]");
      const cards = Array.from(document.querySelectorAll("[data-element-card]"));
      const categories = Array.from(document.querySelectorAll("[data-element-category]"));
      const navItems = Array.from(document.querySelectorAll("[data-element-nav-item]"));
      const navGroups = Array.from(document.querySelectorAll("[data-element-nav-group]"));

      searchInput?.addEventListener("input", () => {
        const query = searchInput.value.trim().toLowerCase();
        let visibleCount = 0;

        cards.forEach((card) => {
          const searchText = (card.dataset.search || "").toLowerCase();
          const visible = !query || searchText.includes(query);
          card.hidden = !visible;
          if (visible) visibleCount += 1;
        });

        categories.forEach((category) => {
          const visibleCards = category.querySelectorAll("[data-element-card]:not([hidden])");
          category.hidden = visibleCards.length === 0;
        });

        navItems.forEach((item) => {
          const target = document.getElementById(item.dataset.navTarget || "");
          item.hidden = Boolean(target?.hidden);
        });

        navGroups.forEach((group) => {
          const visibleItems = group.querySelectorAll("[data-element-nav-item]:not([hidden])");
          const hasVisibleItems = visibleItems.length > 0;
          group.hidden = !hasVisibleItems;
          group.open = Boolean(query && hasVisibleItems);
        });

        if (emptyMessage) {
          emptyMessage.hidden = visibleCount > 0;
        }
      });
    </script>
  </body>
</html>
