---
const { element, index, categoryTitle = "" } = Astro.props;
const cardId = `element-card-${index}`;
const sourceId = `element-source-${index}`;
const sourceCode = element.source || element.html;
const sourceText = `${element.html} ${sourceCode}`.replace(/<[^>]*>/g, " ").replace(/\s+/g, " ").trim();
const searchText = [element.title, element.id, element.description, categoryTitle, sourceText, sourceCode]
  .filter(Boolean)
  .join(" ");
---

<article class="element-card" id={cardId} data-element-card data-search={searchText}>
  <header class="element-card__header">
    <div class="element-card__meta">
      <h3 class="element-card__title">{element.title}</h3>
    </div>
  </header>

  <div class="element-card__preview" set:html={element.html} />

  <section class="element-card__source" aria-labelledby={`${sourceId}-heading`}>
    <div class="element-card__source-header">
      <button class="element-card__copy" type="button" data-copy-source={sourceId}>
        コピー
      </button>
      <h4 class="element-card__source-title" id={`${sourceId}-heading`}>ソースコード</h4>
    </div>
    <pre><code>{sourceCode}</code></pre>
  </section>

  <textarea id={sourceId} class="element-card__clipboard" readonly>{sourceCode}</textarea>
</article>
