---
const { element, index } = Astro.props;
const cardId = `element-card-${index}`;
const sourceId = `element-source-${index}`;
---

<article class="element-card" id={cardId}>
  <header class="element-card__header">
    <h3 class="element-card__title">{element.title}</h3>
    <button class="element-card__copy" type="button" data-copy-source={sourceId}>
      コピー
    </button>
  </header>

  <div class="element-card__preview" set:html={element.html} />

  <details class="element-card__source" open>
    <summary>ソースコード</summary>
    <pre><code>{element.html}</code></pre>
  </details>

  <textarea id={sourceId} class="element-card__clipboard" readonly>{element.html}</textarea>
</article>
